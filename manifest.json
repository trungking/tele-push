{
  "manifest_version": 3,
  "name": "Tele Push",
  "description": "Send current URL, selected text, or clipboard to Telegram bot",
  "version": "1.0",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "clipboardRead"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://api.telegram.org/*"
  ]
}
